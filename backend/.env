# SatoshiSignal — Environment Configuration
# Copy this to .env and fill in your API keys

# ============================================
# AI Engine (Gemini / OpenRouter)
# ============================================
# Required for AI-powered predictions. Get a key at https://aistudio.google.com
GEMINI_API_KEY=AIzaSyCfieLQPuYxCMMObLlZLfL4KkxoUpLPGIw

# Optional: OpenRouter fallback
OPENROUTER_API_KEY=

# ============================================
# Sentiment Data Sources
# ============================================
# NewsData.io for crypto news aggregation
# Get a free key at https://newsdata.io (200 requests/day free tier)
NEWSDATA_API_KEY=pub_33a1e26688a748ceaaf13fcd3a835894

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# Cache TTL (seconds)
# ============================================
CACHE_TTL_MARKET=10
CACHE_TTL_SENTIMENT=120
CACHE_TTL_AI=30
CACHE_TTL_NEWS=300

# ============================================
# AI Model
# ============================================
# Default: gemini-2.5-flash (fast, affordable)
GEMINI_MODEL=gemini-2.5-flash

# ============================================
# Binance WebSocket URLs (defaults work fine)
# ============================================
# BINANCE_WS_TRADE_URL=wss://stream.binance.com:9443/ws/btcusdt@trade
# BINANCE_WS_KLINE_URL=wss://stream.binance.com:9443/ws/btcusdt@kline_1m
