# === SatoshiSignal Backend Environment Variables ===
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control.
# It is already listed in .gitignore.
#
# Required keys will cause the app to fail to start if missing.
# Optional keys disable features gracefully when absent.

# ============================================
# AI Engine (Required)
# ============================================
# Google Gemini API key — required for AI predictions.
# Get a key at https://aistudio.google.com/apikey
# Format: AIza followed by 30-40 alphanumeric chars
GEMINI_API_KEY=

# Optional: OpenRouter API key for alternative AI models
OPENROUTER_API_KEY=

# ============================================
# Sentiment Data Sources (Optional)
# ============================================
# NewsData.io API key — enables crypto news aggregation.
# Free tier: 200 requests/day at https://newsdata.io
# Format: pub_ followed by 24-32 hex chars
NEWSDATA_API_KEY=

# ============================================
# AI Model Override (Optional)
# ============================================
# Defaults to gemma-4-31b-it if not set.
# Other options: gemini-2.5-flash, gemini-2.5-pro
GEMINI_MODEL=gemma-4-31b-it

# ============================================
# Binance WebSocket (Optional — defaults are production-ready)
# ============================================
BINANCE_WS_TRADE_URL=wss://stream.binance.com:9443/ws/btcusdt@trade
BINANCE_WS_KLINE_URL=wss://stream.binance.com:9443/ws/btcusdt@kline_1m

# ============================================
# Cache TTL in seconds
# ============================================
CACHE_TTL_MARKET=10
CACHE_TTL_SENTIMENT=120
CACHE_TTL_AI=30
CACHE_TTL_NEWS=300

# ============================================
# Server
# ============================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
HOST=0.0.0.0
PORT=8000
DEBUG=false