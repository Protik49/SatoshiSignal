# === SatoshiSignal Backend Environment Variables ===

# Google Gemini API Key (required for AI predictions)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (optional, for alternative AI models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# NewsData.io API Key (optional, for crypto news aggregation)
# Get a free key at https://newsdata.io (200 requests/day free tier)
NEWSDATA_API_KEY=your_newsdata_api_key_here

# === Binance WebSocket Configuration ===
# BTC/USDT stream URLs
BINANCE_WS_TRADE_URL=wss://stream.binance.com:9443/ws/btcusdt@trade
BINANCE_WS_KLINE_URL=wss://stream.binance.com:9443/ws/btcusdt@kline_1m

# === Cache Configuration ===
# TTL in seconds for various caches
CACHE_TTL_MARKET=10
CACHE_TTL_SENTIMENT=120
CACHE_TTL_AI=30
CACHE_TTL_NEWS=300

# === CORS ===
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Server ===
HOST=0.0.0.0
PORT=8000
DEBUG=false
